# --- Database (Neon Postgres) ---
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require"

# --- Auth0 ---
# Create an Auth0 Application (Regular Web App). Set:
#   Allowed Callback URLs: http://localhost:3000/auth/callback, https://yourdomain.com/auth/callback
#   Allowed Logout URLs:   http://localhost:3000, https://yourdomain.com
AUTH0_DOMAIN="your-tenant.auth0.com"
AUTH0_CLIENT_ID=""
AUTH0_CLIENT_SECRET=""
AUTH0_SECRET="generate-with:-openssl-rand-hex-32"
APP_BASE_URL="http://localhost:3000"

# Comma-separated list of admin emails allowed to access /admin
ADMIN_EMAILS="you@example.com"

# --- Brevo (transactional email) ---
# Get API key from https://app.brevo.com/settings/keys/api
# EMAIL_FROM must use a sender address verified in Brevo (Senders & IP)
BREVO_API_KEY="xkeysib-..."
EMAIL_FROM="UPIN <noreply@yourdomain.com>"
EMAIL_NOTIFY_TO="sales@yourdomain.com"
